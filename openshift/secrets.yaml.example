# =============================================================================
# Secrets override file — copy to secrets.yaml and fill in real values.
# Usage: helm install -f values.yaml -f secrets.yaml ...
#
# secrets.yaml is git-ignored to prevent accidental credential commits.
# =============================================================================

secrets:
  # Google AI Studio API key (or use gcpServiceAccountKey below for Vertex AI)
  googleApiKey: ""
  googleCloudProject: ""
  redHatSsoClientId: ""
  redHatSsoClientSecret: ""
  sessionDbPassword: ""
  sessionDatabaseUrl: "postgresql+asyncpg://sessions:<password>@lightspeed-agent-postgresql:5432/agent_sessions"
  marketplaceDbPassword: ""
  databaseUrl: "postgresql+asyncpg://marketplace:<password>@lightspeed-agent-marketplace-postgresql:5432/marketplace"
  redisPassword: ""
  dcrEncryptionKey: ""
  gmaClientId: ""
  gmaClientSecret: ""
  # GCP service account key JSON (alternative to googleApiKey for Vertex AI auth)
  gcpServiceAccountKey: ""
